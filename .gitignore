# Secrets — never commit
.env

# Portal mode's local sqlite fallback store (created by `python -m fireflyer.portal`
# when no DATABASE_URL is set)
portal.db

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# OS
.DS_Store

# Local agent/editor config
.claude/

# Local dataset object store (Parquet + YAML metadata, generated/uploaded)
/data/

# Local "paths" (your dashboards live here; the demo path is seeded on first
# run). Keep your own dashboards in their own git repo, not this one.
/paths/
